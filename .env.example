# Puerto del servidor (Render lo asigna automáticamente con PORT)
PORT=3000

# Dominio (para sitemap, robots.txt, canonical URLs)
DOMAIN=elpodiomp.com.ar
BASE_URL=https://elpodiomp.com.ar

# Credenciales de tu Aplicación en Mercado Libre Developers
# Obténlas en: https://developers.mercadolibre.com.ar/
MELI_CLIENT_ID=tu_client_id_aca
MELI_CLIENT_SECRET=tu_client_secret_aca

# Tu API Key de Google Gemini (necesaria para agregar locales de comida con IA)
# Obténla en: https://aistudio.google.com/
GEMINI_API_KEY=tu_gemini_api_key_aca

# Opcional: Token de producción permanente directo (evita tener que hacer OAuth)
# Obténlo en la pestaña "Productivas" del panel de credenciales de Mercado Pago
MELI_ACCESS_TOKEN=tu_access_token_productivo_aca
